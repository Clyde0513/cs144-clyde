{
    "compilerOptions": {
      "target": "ES2020",
      "module": "NodeNext",
      "moduleResolution": "NodeNext",
      "esModuleInterop": true,
      "allowJs": true,
      "resolveJsonModule": true,
      "outDir": ".",
      "rootDir": ".",
      "strict": true,
      "skipLibCheck": true
    },
    "include": ["./**/*.ts"],
    "exclude": [
      "node_modules",
      "tests"
    ]
}